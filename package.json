{
  "name": "bullmq-prometheus-exporter",
  "description": "Prometheus exporter for BullMQ queue metrics",
  "module": "index.ts",
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "keywords": [
    "bullmq",
    "prometheus",
    "redis",
    "metrics",
    "observability"
  ],
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "dev": "bun --hot index.ts",
    "start": "bun run index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run format && bun run lint && bun run typecheck && bun test"
  },
  "type": "module",
  "dependencies": {
    "bullmq": "^5.71.0"
  }
}
